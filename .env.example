# Production domain / Socket.IO
# Set these in Render once your Wix DNS points at Render.
PUBLIC_SITE_URL=https://yourdomain.com
CLIENT_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
VITE_PUBLIC_SITE_URL=https://yourdomain.com
# Usually leave VITE_SOCKET_URL blank because the client connects to window.location.origin.
# Use it only if the frontend and socket server are on different domains.
VITE_SOCKET_URL=

# Stripe checkout link used by the Support button on the home page.
VITE_STRIPE_SUPPORT_URL=https://buy.stripe.com/YOUR_CHECKOUT_LINK

# First-run default for the Support/Stripe home button.
# After the server creates server/data/siteSettings.json, use dev console commands:
# support enable / support disable / support status
SUPPORT_UI_ENABLED=true
